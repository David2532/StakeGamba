{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["frontend/src/**/*.ts", "math/**/*.ts"],
  "exclude": ["node_modules", "frontend/dist", "math/library", "_archive", "backend"]
}
