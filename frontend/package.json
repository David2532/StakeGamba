{
  "name": "golden-goal-rush-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "typecheck": "tsc -p ../tsconfig.json",
    "build:math:compile": "tsc ../math/src/math.ts --outDir ../math/library/publish_files/golden_goal_rush --module ES2020 --target ES2020 --lib DOM,ES2020 --skipLibCheck",
    "build:math": "npm run build:math:compile && node ../math/scripts/generateStakePublish.mjs",
    "build": "vite build && node scripts/inlineDist.mjs",
    "prepare-package": "npm run build:math && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "detect-libc": "^2.1.2",
    "fdir": "^6.5.0",
    "lightningcss": "^1.32.0",
    "nanoid": "^3.3.12",
    "phaser": "^3.90.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "rolldown": "^1.0.3",
    "source-map-js": "^1.2.1",
    "tinyglobby": "^0.2.17"
  }
}
